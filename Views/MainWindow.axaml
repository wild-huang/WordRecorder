<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WordRecorder.ViewModels"
        xmlns:m="using:WordRecorder.Models"
        xmlns:converters="using:WordRecorder.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="WordRecorder.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="Root"
        Title="生词记录"
        Width="900" Height="700"
        MinWidth="600" MinHeight="500"
        Background="Transparent"
        TransparencyLevelHint="Mica"
        CornerRadius="8">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Styles>

    <Grid>
        <!-- Main Content -->
        <DockPanel IsVisible="{Binding !IsSettingsOpen}">
            <!-- Title Bar with Subtle Gradient -->
            <Border DockPanel.Dock="Top" Height="56" 
                    Padding="20,0" CornerRadius="12,12,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                        <GradientStop Color="#F5E6E8" Offset="0"/>
                        <GradientStop Color="#F0D4D8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <TextBlock Text="📖" FontSize="24" VerticalAlignment="Center"/>
                        <TextBlock Text="生词记录" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="#8B7B8B"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                        <Button Content="⚙ 设置" Command="{Binding ToggleSettingsCommand}"
                                Padding="16,10" CornerRadius="10"
                                Background="#E8D8DC"
                                Foreground="#8B7B8B"/>
                        <Button Content="📤 导出" Command="{Binding ExportCommand}" 
                                CommandParameter="{Binding #Root}"
                                Padding="16,10" CornerRadius="10"
                                Background="#E8D8DC"
                                Foreground="#8B7B8B"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Input Area -->
            <Border DockPanel.Dock="Top" Padding="20,16">
                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="14" Padding="24,18">
                    <StackPanel Spacing="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="添加单词：" VerticalAlignment="Center" 
                                       Margin="0,0,16,0" FontSize="17" FontWeight="Medium"/>
                            <Border DockPanel.Dock="Right" Width="16" Height="16" CornerRadius="8"
                                    Margin="12,0,0,0" VerticalAlignment="Center">
                                <Border.Background>
                                    <MultiBinding Converter="{x:Static converters:WordExistsConverter.Instance}">
                                        <Binding Path="WordExists"/>
                                        <Binding Path="CurrentInput"/>
                                    </MultiBinding>
                                </Border.Background>
                            </Border>
                            <TextBox Text="{Binding CurrentInput}" 
                                     Watermark="输入英文单词，按回车添加..."
                                     FontSize="17"
                                     KeyDown="OnInputKeyDown"
                                     AcceptsReturn="False"
                                     IsEnabled="{Binding !IsLooking}"
                                     CornerRadius="10"/>
                        </DockPanel>
                        
                        <!-- Suggestions -->
                        <StackPanel Spacing="6" IsVisible="{Binding !IsLooking}">
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        IsVisible="{Binding SuggestedWords.Count}">
                                <TextBlock Text="你可能想输入：" FontSize="14" 
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           VerticalAlignment="Center"/>
                                <ItemsControl ItemsSource="{Binding SuggestedWords}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border Background="{DynamicResource SystemControlAccentAcrylicBackgroundAccentBrushHigh}"
                                                    CornerRadius="8" Padding="12,6" Cursor="Hand"
                                                    PointerPressed="OnSuggestionTapped">
                                                <TextBlock Text="{Binding}" FontSize="14"
                                                           Foreground="{DynamicResource SystemControlForegroundOnAccentBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Status Bar -->
            <Border DockPanel.Dock="Bottom" Padding="20,12" 
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="0,0,12,12">
                <DockPanel>
                    <TextBlock Text="{Binding StatusText}" FontSize="14" 
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" 
                               Text="{Binding Words.Count, StringFormat='共 {0} 个单词'}"
                               FontSize="14" 
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Word List grouped by date -->
            <Border Margin="20,10">
                <ListBox ItemsSource="{Binding DateGroups}" 
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:DateGroup">
                            <Expander Header="{Binding DateDisplay}" IsExpanded="True" Margin="0,0,0,10"
                                      CornerRadius="12">
                                <ItemsControl ItemsSource="{Binding Words}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="m:Word">
                                            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                                    CornerRadius="10" Padding="18,14" Margin="0,0,0,8">
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right" Content="✕" 
                                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteWordCommand}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                            Padding="10,6" Margin="10,0,0,0"
                                                            VerticalAlignment="Center"
                                                            CornerRadius="8"/>
                                                    <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                                                        <StackPanel Orientation="Horizontal" Spacing="14">
                                                            <TextBlock Text="{Binding Term}" FontSize="19" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                                                            <TextBlock Text="{Binding Phonetic}" FontSize="15" 
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                            <!-- 查询次数显示 -->
                                                            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                                                    CornerRadius="6" Padding="8,3"
                                                                    IsVisible="{Binding ShowLookupCount}">
                                                                <TextBlock Text="{Binding LookupCountText}" FontSize="12"
                                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Translation}" FontSize="15" TextWrapping="Wrap"/>
                                                        
                                                        <!-- Possible correction -->
                                                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                                                CornerRadius="8" Padding="10,6"
                                                                IsVisible="{Binding IsPossibleMistake}">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock Text="可能为：" FontSize="13"
                                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                                <TextBlock Text="{Binding SuggestedCorrection}" FontSize="13"
                                                                           Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                                           FontWeight="Medium"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </DockPanel>

        <!-- Settings Panel (Overlay) -->
        <Border IsVisible="{Binding IsSettingsOpen}"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                CornerRadius="12" Padding="0">
            <DockPanel>
                <!-- Settings Header with Subtle Gradient -->
                <Border DockPanel.Dock="Top" Height="56" 
                        Padding="20,0" CornerRadius="12,12,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                            <GradientStop Color="#F5E6E8" Offset="0"/>
                            <GradientStop Color="#F0D4D8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="14">
                            <Button Content="← 返回" Command="{Binding ToggleSettingsCommand}"
                                    Padding="14,8" CornerRadius="8"
                                    Background="#E8D8DC"
                                    Foreground="#8B7B8B"/>
                            <TextBlock Text="⚙ 设置" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                                       Foreground="#8B7B8B"/>
                        </StackPanel>

                        <Button Grid.Column="2" Content="💾 保存" Command="{Binding ApplySettingsCommand}"
                                Padding="16,10" CornerRadius="10" VerticalAlignment="Center"
                                Background="#E8D8DC"
                                Foreground="#8B7B8B"/>
                    </Grid>
                </Border>

                <!-- Settings Content -->
                <ScrollViewer Padding="24">
                    <StackPanel Spacing="20" MaxWidth="650">
                        <!-- Theme Section -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="14" Padding="24">
                            <StackPanel Spacing="18">
                                <TextBlock Text="🎨 主题设置" FontSize="17" FontWeight="SemiBold"/>
                                
                                <StackPanel Spacing="10">
                                    <TextBlock Text="应用主题" FontSize="15"/>
                                    <ComboBox ItemsSource="{Binding Settings.Themes}" 
                                              SelectedItem="{Binding Settings.Theme}"
                                              HorizontalAlignment="Stretch"
                                              CornerRadius="10"
                                              SelectionChanged="OnThemeChanged"/>
                                </StackPanel>

                                <!-- Sunset Presets with Subtle Gradient -->
                                <StackPanel Spacing="10">
                                    <TextBlock Text="🌅 晚霞配色" FontSize="15" FontWeight="Medium"/>
                                    <Border CornerRadius="12" Padding="12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                                <GradientStop Color="#F8EDEE" Offset="0"/>
                                                <GradientStop Color="#F0D8DC" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ItemsControl ItemsSource="{Binding SunsetPresets}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ColorPreset">
                                                    <Border CornerRadius="10" Padding="14,10" Margin="5"
                                                            Cursor="Hand"
                                                            PointerPressed="OnPresetColorSelected">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{Binding Color}" Opacity="0.9"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                                   Foreground="White" FontWeight="SemiBold"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>

                                <!-- Custom Color Picker -->
                                <StackPanel Spacing="12">
                                    <TextBlock Text="🎨 自定义颜色" FontSize="15" FontWeight="Medium"/>
                                    
                                    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                            CornerRadius="12" Padding="18">
                                        <StackPanel Spacing="16">
                                            <!-- Color preview and hex -->
                                            <StackPanel Orientation="Horizontal" Spacing="16">
                                                <Border Width="56" Height="56" CornerRadius="14"
                                                        Background="{Binding Settings.AccentColor}"
                                                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                        BorderThickness="2"/>
                                                <StackPanel Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock Text="HEX 颜色代码" FontSize="12"
                                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                    <TextBox Text="{Binding HexInput}" 
                                                             Width="140" CornerRadius="8"
                                                             FontSize="15"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <!-- RGB Sliders -->
                                            <StackPanel Spacing="12">
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="R" Width="24" VerticalAlignment="Center" FontWeight="Medium"/>
                                                    <Slider Minimum="0" Maximum="255" Value="{Binding RedChannel}"
                                                            Width="220" CornerRadius="4"/>
                                                    <TextBlock Text="{Binding RedChannel, StringFormat={}{0:F0}}" 
                                                               Width="40" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="G" Width="24" VerticalAlignment="Center" FontWeight="Medium"/>
                                                    <Slider Minimum="0" Maximum="255" Value="{Binding GreenChannel}"
                                                            Width="220" CornerRadius="4"/>
                                                    <TextBlock Text="{Binding GreenChannel, StringFormat={}{0:F0}}" 
                                                               Width="40" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="B" Width="24" VerticalAlignment="Center" FontWeight="Medium"/>
                                                    <Slider Minimum="0" Maximum="255" Value="{Binding BlueChannel}"
                                                            Width="220" CornerRadius="4"/>
                                                    <TextBlock Text="{Binding BlueChannel, StringFormat={}{0:F0}}" 
                                                               Width="40" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <Button Content="应用自定义颜色" 
                                                    Command="{Binding ApplyCustomColorCommand}"
                                                    Padding="16,10" CornerRadius="8"
                                                    HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Current color display -->
                                    <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,6,0,0">
                                        <Border Width="36" Height="36" CornerRadius="18"
                                                Background="{Binding Settings.AccentColor}"
                                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                BorderThickness="2"/>
                                        <TextBlock Text="{Binding Settings.AccentColor, StringFormat='当前主题色: {0}'}" 
                                                   VerticalAlignment="Center" FontSize="14"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- AI Section -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="14" Padding="24">
                            <StackPanel Spacing="18">
                                <StackPanel Orientation="Horizontal" Spacing="14">
                                    <TextBlock Text="🤖 AI 设置" FontSize="17" FontWeight="SemiBold"/>
                                    <ToggleSwitch IsChecked="{Binding Settings.AiEnabled}" 
                                                  OnContent="已启用" OffContent="已禁用"/>
                                </StackPanel>
                                
                                <StackPanel Spacing="10" IsVisible="{Binding Settings.AiEnabled}">
                                    <TextBlock Text="API 端点" FontSize="14"/>
                                    <TextBox Text="{Binding Settings.AiEndpoint}" Watermark="https://api.example.com/v1"
                                             CornerRadius="8"/>
                                    
                                    <TextBlock Text="API 密钥" FontSize="14" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding Settings.AiApiKey}" Watermark="sk-..."
                                             CornerRadius="8"/>
                                    
                                    <TextBlock Text="模型名称" FontSize="14" Margin="0,8,0,0"/>
                                    <TextBox Text="{Binding Settings.AiModel}" Watermark="gpt-3.5-turbo"
                                             CornerRadius="8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Dictionary Section -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="14" Padding="24">
                            <StackPanel Spacing="18">
                                <StackPanel Orientation="Horizontal" Spacing="14">
                                    <TextBlock Text="📚 词典设置" FontSize="17" FontWeight="SemiBold"/>
                                    <ToggleSwitch IsChecked="{Binding Settings.DictEnabled}" 
                                                  OnContent="已启用" OffContent="已禁用"/>
                                </StackPanel>
                                
                                <StackPanel Spacing="10" IsVisible="{Binding Settings.DictEnabled}">
                                    <TextBlock Text="支持灵格斯词霸 LD2/LDX 格式及 TXT/CSV 词表" FontSize="13"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    
                                    <TextBlock Text="词典路径" FontSize="14"/>
                                    <DockPanel>
                                        <TextBox Text="{Binding Settings.LingoesDictPath}" 
                                                 Watermark="选择词典文件..."
                                                 IsReadOnly="True" DockPanel.Dock="Left"
                                                 CornerRadius="8"/>
                                        <Button Content="浏览..." Command="{Binding ImportDictionaryCommand}"
                                                CommandParameter="{Binding #Root}"
                                                Padding="14,8" CornerRadius="8" Margin="10,0,0,0"/>
                                    </DockPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- About Section -->
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="14" Padding="24">
                            <StackPanel Spacing="10">
                                <TextBlock Text="ℹ 关于" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="生词记录 v1.0" FontSize="15"/>
                                <TextBlock Text="一款简洁的生词记录工具，支持有道词典查询、AI 猜词、多格式导出。"
                                           FontSize="14" TextWrapping="Wrap"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
